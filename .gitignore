# Dependencies
node_modules/

# Build output
dist/
build/

# Environment & secrets
.env
.env.local
.env.production
.env.*.local
# Keep .env.example tracked (it has no secrets)
!.env.example

# Database (generated from seed)
server/db/*.db
server/db/*.db-wal
server/db/*.db-shm

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo

# Python (in case any tooling generates these)
__pycache__/
*.pyc

# Logs & cache
*.log
npm-debug.log*
.cache/
.parcel-cache/
.vite/

# Vercel
.vercel/
