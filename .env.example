# ── Frontend (Vite) ──────────────────────────────────────
# URL of the backend API. Leave empty for local dev (uses Vite proxy).
# In production (Vercel), set this to your Render backend URL.
# Example: https://netflix-analytics-api.onrender.com
VITE_API_URL=

# ── Backend (Express) ────────────────────────────────────
# Port for the Express server (Render sets this automatically)
PORT=3001

# Comma-separated allowed origins for CORS.
# In production, set this to your Vercel frontend URL.
# Example: https://netflix-content-analytics.vercel.app
CORS_ORIGIN=
